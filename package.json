{
  "name": "service-json-keys-project",
  "version": "2.4.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-novel/service-json-keys.git"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "workspaces": [
    ".",
    "pkg/js/rest",
    "pkg/js/test/rest"
  ],
  "scripts": {
    "build": "pnpm build:rest && pnpm types:rest && pnpm types:rest-test",
    "build:rest": "rm -rf ./pkg/js/rest/dist && vite build --outDir ./pkg/js/rest/dist -c pkg/js/rest/vite.config.ts",
    "format": "pnpm format:go && pnpm format:proto && pnpm format:js",
    "format:go": "go mod tidy && go tool -modfile=golangci-lint.mod golangci-lint run ./... --fix",
    "format:js": "prettier --write . --config prettier.config.ts",
    "format:proto": "go tool buf format -w && go tool buf dep update",
    "generate": "pnpm run generate:go",
    "generate:go": "go generate ./...",
    "preinstall": "npx only-allow pnpm",
    "lint": "pnpm lint:go && pnpm lint:proto && pnpm lint:js",
    "lint:ci": "pnpm build && pnpm i && pnpm lint:js",
    "lint:eslint": "eslint .",
    "lint:go": "go tool -modfile=golangci-lint.mod golangci-lint run ./...",
    "lint:js": "pnpm lint:stylecheck && pnpm lint:typecheck && pnpm lint:eslint && pnpm run lint:openapi",
    "lint:openapi": "pnpm redocly lint openapi.yaml",
    "lint:proto": "go tool buf lint",
    "lint:stylecheck": "prettier --check . --config prettier.config.ts",
    "lint:typecheck": "pnpm lint:typecheck:base && pnpm lint:typecheck:rest && pnpm lint:typecheck:test:rest",
    "lint:typecheck:base": "tsc --noEmit",
    "lint:typecheck:rest": "pnpm tsc --p ./pkg/js/rest/tsconfig.json --noEmit",
    "lint:typecheck:test:rest": "pnpm tsc --p ./pkg/js/test/rest/tsconfig.json --noEmit",
    "prepublish:doc": "pnpm prepublish:doc:readme && pnpm prepublish:doc:openapi",
    "prepublish:doc:openapi": "a-novel publish stamp 'version: ' openapi.yaml",
    "prepublish:doc:readme": "a-novel publish stamp 'a-novel/service-json-keys/[^/]+' README.md",
    "sync": "pnpm build && pnpm i",
    "test": "vitest run -c vitest.config.ts",
    "test:ci": "pnpm build && pnpm i && pnpm test",
    "types:rest": "tsc --build pkg/js/rest/tsconfig.build.json",
    "types:rest-test": "tsc --p ./pkg/js/test/rest/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@a-novel-kit/nodelib-browser": "^1.3.18",
    "@a-novel-kit/nodelib-config": "^1.3.18",
    "@a-novel-kit/nodelib-test": "^1.3.18",
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "^2.20.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-storybook": "^10.2.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sql": "^0.20.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.16",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=23.11.0",
    "npm": ">=10.9.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
